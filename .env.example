# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-change-in-production

# Google OAuth Provider
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth Provider
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Database - PostgreSQL (Required for Prisma)
# For local development, you can use a free hosted DB like:
# - Supabase: https://supabase.com (free tier)
# - Neon: https://neon.tech (free tier)
# - Railway: https://railway.app (free tier)
DATABASE_URL=postgresql://user:password@localhost:5432/landing_page_builder

# AI Providers (Optional - at least one required for AI features)
# Z.AI GLM-4.7 is recommended for Hebrew content
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
ZHIPU_API_KEY=your-zhipu-api-key  # Recommended for Hebrew - https://z.ai

# Application Settings
NODE_ENV=development